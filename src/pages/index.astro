---
import SiteLayout from '../layouts/SiteLayout.astro';
import { eq, desc } from 'drizzle-orm';
import { getDb, schema } from '../lib/db';

const storeUrl = 'https://store.seayniclabs.com/products/stdout-self-host';
const db = getDb();
const previewDocs = db.select({
  id: schema.communitySubmissions.id,
  title: schema.communitySubmissions.sanitizedTitle,
  docType: schema.communitySubmissions.docType,
  tags: schema.communitySubmissions.tags,
  publishedAt: schema.communitySubmissions.publishedAt,
}).from(schema.communitySubmissions)
  .where(eq(schema.communitySubmissions.status, 'published'))
  .orderBy(desc(schema.communitySubmissions.publishedAt))
  .limit(6)
  .all();
---
<SiteLayout title="StdOut — You've already solved this">
  <section class="hero">
    <div class="hero-badge mono">INCIDENT MEMORY FOR YOUR INFRASTRUCTURE</div>
    <h1>You've already solved this.<br /><span class="dim">You just don't remember.</span></h1>
    <p class="hero-sub">StdOut is your self-hosted incident companion. When something breaks at 2am, it pulls up how you fixed it last time — your stack, your resolutions, your runbooks.</p>
    <div class="hero-cta">
      <a href={storeUrl} class="btn btn-primary btn-lg btn-glow" target="_blank" rel="noopener">Self-Host for $149</a>
      <a href="/library" class="btn btn-ghost btn-lg">Browse the Library</a>
    </div>
    <p class="hero-note mono">$149 one-time · Docker · Your infra, your data, forever</p>
    <div class="hud mono">
      <div class="hud-bar"><span class="hud-dot"></span> SCANNING · stdout scanner</div>
      <div class="hud-body">
        <div><span class="ts">00:00.34</span> Discovered <span class="acc">53 containers</span> across 12 compose projects</div>
        <div><span class="ts">00:01.03</span> TLS: 14 valid, <span class="warn">2 expiring &lt;30d</span></div>
        <div class="result"><span class="ts">00:01.44</span> Stack fingerprint complete — <span class="acc">ready for incident matching</span></div>
      </div>
    </div>
  </section>

  <section class="section" id="how">
    <h2>How it works</h2>
    <div class="steps">
      <div class="step"><span class="num mono">01</span><h3>Install</h3><p>Copy docker-compose, set <code>APP_URL</code> and <code>SECRET_KEY</code>, run <code>docker compose up</code>.</p></div>
      <div class="step"><span class="num mono">02</span><h3>Scan</h3><p>Run the scanner once. It maps containers, ports, networks, and certs across your homelab.</p></div>
      <div class="step"><span class="num mono">03</span><h3>Monitor</h3><p>Windlass watches your schedule — scale down idle services, keep critical paths up. StdOut HUD tracks health.</p></div>
      <div class="step"><span class="num mono">04</span><h3>Resolve</h3><p>Log incidents, get AI diagnosis against your history, save runbooks. Next time, the fix surfaces automatically.</p></div>
    </div>
  </section>

  <section class="section windlass">
    <h2>StdOut + Windlass</h2>
    <p>They install together and watch each other. <strong>Windlass runs as a separate container</strong> so it can watch StdOut itself — if StdOut crashes, Windlass is still up and can restart it. Windlass handles schedule-aware start/stop; StdOut handles incidents, runbooks, and the community knowledge base.</p>
  </section>

  <section class="section" id="features">
    <h2>What you get</h2>
    <div class="feat-grid">
      <div class="card"><h3>HUD dashboard</h3><p>HTTP/TCP checks, sparklines, auto-incidents when services go down.</p></div>
      <div class="card"><h3>Stack Scanner</h3><p>One command discovers Docker, compose projects, TLS, and network gear.</p></div>
      <div class="card"><h3>AI diagnosis</h3><p>Claude matches incidents to your stack context and past resolutions.</p></div>
      <div class="card"><h3>Community KB</h3><p>Sync runbooks and postmortems from this library into your instance.</p></div>
      <div class="card"><h3>Runbook library</h3><p>Turn fixes into searchable docs — yours plus community contributions.</p></div>
      <div class="card"><h3>Weekly digest</h3><p>Email summary of incidents, resolutions, and stack health.</p></div>
    </div>
  </section>

  <section class="section">
    <h2>Community Library</h2>
    <p class="sub">Operational runbooks and postmortems from builders like you — synced into every self-hosted instance.</p>
    <div class="lib-preview">
      {previewDocs.map(doc => (
        <a href={`/library/${doc.id}`} class="lib-card card">
          <span class="badge">{doc.docType}</span>
          <h3>{doc.title}</h3>
          {doc.tags && <p class="tags mono">{doc.tags}</p>}
        </a>
      ))}
    </div>
    <p style="margin-top: 20px;"><a href="/library">Browse all community docs →</a></p>
  </section>

  <section class="section install">
    <h2>Quick start</h2>
    <pre class="mono install-block"><code># 1. Get the image from the store after purchase
docker load &lt; stdout-self-host.tar.gz

# 2. Copy compose + .env from your order
cp docker-compose.yml .env.example .env
# Edit APP_URL and SECRET_KEY

# 3. Start StdOut + Windlass
docker compose up -d

# 4. Open your URL and complete setup wizard
open http://localhost:8112</code></pre>
  </section>

  <section class="section" id="pricing">
    <h2>Own it. Run it. Keep it.</h2>
    <div class="price-card card featured">
      <span class="badge">Self-Host</span>
      <div class="price mono">$149 <span class="per">once</span></div>
      <ul>
        <li>Full feature set — no gates</li>
        <li>Docker Compose + bundled Windlass</li>
        <li>Unlimited stacks, incidents, storage</li>
        <li>Your data stays on your network</li>
        <li>Bring your own Anthropic API key</li>
      </ul>
      <a href={storeUrl} class="btn btn-primary btn-glow" style="width:100%;margin-top:16px" target="_blank" rel="noopener">Get Self-Hosted</a>
    </div>
  </section>
</SiteLayout>

<style>
  .hero { text-align: center; padding: 60px 24px 40px; max-width: 860px; margin: 0 auto; }
  .hero-badge { font-size: 11px; letter-spacing: 0.12em; color: var(--accent-light); margin-bottom: 16px; }
  .hero h1 { font-size: clamp(28px, 5vw, 48px); font-weight: 800; line-height: 1.1; margin-bottom: 20px; }
  .dim { color: var(--text-muted); }
  .hero-sub { color: var(--text-secondary); max-width: 560px; margin: 0 auto 24px; font-size: 16px; }
  .hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 10px; }
  .hero-note { font-size: 11px; color: var(--text-muted); margin-bottom: 40px; }
  .hud { max-width: 560px; margin: 0 auto; text-align: left; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; font-size: 12px; }
  .hud-bar { padding: 10px 14px; background: var(--bg-surface); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 8px; color: var(--accent-light); }
  .hud-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  .hud-body { padding: 14px; line-height: 1.9; color: var(--text-muted); }
  .ts { opacity: 0.5; margin-right: 8px; }
  .acc { color: var(--accent-light); }
  .warn { color: var(--warning); }
  .result { color: var(--text-secondary); }
  .section { max-width: 900px; margin: 0 auto; padding: 56px 24px; }
  .section h2 { font-size: 26px; margin-bottom: 24px; text-align: center; }
  .sub { text-align: center; color: var(--text-secondary); margin: -12px 0 28px; }
  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; }
  .step { text-align: center; }
  .num { color: var(--accent); font-size: 12px; font-weight: 700; }
  .step h3 { margin: 8px 0; font-size: 16px; }
  .step p { font-size: 13px; color: var(--text-secondary); }
  .windlass p { color: var(--text-secondary); max-width: 720px; margin: 0 auto; text-align: center; line-height: 1.7; }
  .feat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .feat-grid h3 { font-size: 15px; margin-bottom: 8px; }
  .feat-grid p { font-size: 13px; color: var(--text-secondary); }
  .lib-preview { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; }
  .lib-card { display: block; color: inherit; transition: border-color 0.15s; }
  .lib-card:hover { border-color: var(--accent); }
  .lib-card h3 { font-size: 15px; margin: 10px 0 6px; color: var(--text); }
  .tags { font-size: 11px; color: var(--text-muted); }
  .install-block { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; font-size: 12px; line-height: 1.8; overflow-x: auto; }
  .price-card { max-width: 400px; margin: 0 auto; text-align: center; }
  .price-card.featured { border-color: rgba(249,115,22,0.35); }
  .price { font-size: 36px; font-weight: 700; margin: 12px 0; }
  .per { font-size: 14px; color: var(--text-muted); }
  .price-card ul { text-align: left; list-style: none; font-size: 14px; color: var(--text-secondary); }
  .price-card li { padding: 6px 0; }
  .price-card li::before { content: '✓ '; color: var(--accent-light); }
</style>
