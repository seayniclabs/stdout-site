# Required — admin review UI
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>

# Optional — session signing (defaults to ADMIN_PASSWORD)
SESSION_SECRET=<random-32-chars>

# Public site URL (HTTPS in production)
SITE_URL=https://stdout.seayniclabs.com

# Database path (default in compose: /app/data/stdout-site.db)
DB_PATH=./data/stdout-site.db
